# Sanity — from manage.sanity.io after `npx sanity init`
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Stripe — from dashboard.stripe.com (test mode keys to start)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: a Shipping Rate ID from Settings > Shipping in the Stripe Dashboard
STRIPE_SHIPPING_RATE_ID=

# Used to build absolute success/cancel URLs for Stripe Checkout
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — optional, for the wholesale inquiry form to actually email you.
# Without these set, inquiries are just logged server-side.
RESEND_API_KEY=
WHOLESALE_NOTIFY_EMAIL=
